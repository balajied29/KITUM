# Backend REST base — the Next `/api/*` rewrite proxies here (see next.config.js).
# In dev this is your local backend; in prod, the hosted backend URL.
NEXT_PUBLIC_API_URL=https://api.kitum.online

# Socket.IO endpoint. WebSockets can't go through the Next rewrite, so this must
# point DIRECTLY at the persistent backend. Usually same host as the API.
# Defaults to NEXT_PUBLIC_API_URL if unset.
NEXT_PUBLIC_SOCKET_URL=https://api.kitum.online

# Mapbox public token (pk.*) — live tracking map rendering.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# Google Maps JS key (browser) — Places autocomplete on the instant order page.
# Restrict by HTTP referrer + enable Maps JavaScript API + Places API.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_browser_key
