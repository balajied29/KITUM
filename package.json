{
  "name": "kit-um",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:fulfiller": "npm --prefix fulfiller run start",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "npm --prefix backend run start",
    "seed": "npm --prefix backend run seed:products && npm --prefix backend run seed:admin && npm --prefix backend run seed:fulfillers",
    "push:all": "bash scripts/push-all.sh"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
