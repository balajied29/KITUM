# Expo exposes EXPO_PUBLIC_* vars to the app at build/runtime.
# Point these at the persistent backend (the hosted URL in prod, your LAN IP in
# local device testing — NOT localhost, since the phone can't reach your Mac's localhost).
# IMPORTANT: this .env is gitignored and therefore NOT seen by EAS cloud builds.
# The values that ship in the APK come from eas.json `build.<profile>.env`.

EXPO_PUBLIC_API_URL=https://api.kitum.online
EXPO_PUBLIC_SOCKET_URL=https://api.kitum.online
