# Expo exposes EXPO_PUBLIC_* vars to the app at build/runtime.
# Point these at the persistent backend (Railway in prod, your LAN IP in dev —
# NOT localhost, since the phone can't reach your machine's localhost).

EXPO_PUBLIC_API_URL=http://192.168.1.10:5000
EXPO_PUBLIC_SOCKET_URL=http://192.168.1.10:5000
