# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/kitum

# JWT / sessions
JWT_SECRET=your_jwt_secret_key_here
# Short-lived access token (Bearer + socket handshake). e.g. 15m, 1h.
ACCESS_TOKEN_TTL=15m
# Rotating refresh token lifetime (days). Reused/revoked tokens nuke the family.
REFRESH_TOKEN_TTL_DAYS=30

# Field-level encryption key for sensitive identifiers at rest (PAN, driving
# licence, bank account numbers). REQUIRED — the server refuses to boot without it.
# Generate a 32-byte key:  openssl rand -base64 32
# Keep it SECRET and STABLE — changing it makes existing encrypted values
# unreadable. After setting it on an existing DB, run:  npm run migrate:encrypt
FIELD_ENCRYPTION_KEY=your_32_byte_base64_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Nodemailer (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_smtp_username
MAIL_PASS=your_smtp_password
MAIL_FROM=noreply@shillongwater.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# WhatsApp — Interakt API
# Base64-encoded API key from app.interakt.ai → Settings → API Keys
INTERAKT_API_KEY=your_interakt_api_key_base64

# ---- Instant (ride-hailing) flow ----

# Google Maps Platform — server-side geocoding (address ⇄ coords).
# Restrict the key to the Geocoding API + your server IP.
GOOGLE_MAPS_API_KEY=your_google_maps_server_key

# Mapbox — driving distance + ETA for dispatch/tracking (Directions API).
MAPBOX_TOKEN=your_mapbox_secret_or_public_token

# Expo push (optional). Needed only if your Expo project enforces a token.
# Create at expo.dev → Account → Access Tokens.
EXPO_ACCESS_TOKEN=

# ---- KYC document storage (S3-compatible: AWS S3 or Cloudflare R2) ----
# Private bucket holding partner PAN / driver's-licence images. Admins view them
# via short-lived presigned URLs; the bucket must NOT be public.
# For Cloudflare R2: set S3_ENDPOINT to your account endpoint and S3_REGION=auto.
# For AWS S3: leave S3_ENDPOINT blank and set the real region.
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=kitum-kyc
S3_ACCESS_KEY_ID=your_r2_or_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_r2_or_s3_secret_access_key

# CLIENT_URL may be a comma-separated list (customer PWA + admin origins) for
# both CORS and Socket.IO, e.g. https://app.shillongwater.com,https://admin...
